class mooving_object: world_object
{
mooving_object(int x, int y, int z = 0)
{
super(x,y,z);
}
void move(string dir)
{
if(dir == "up")
{
pos.z++;
}
else if(dir == "down")
{
pos.z--;
}
else if(dir == "forward")
{
pos.y++;
}
else if(dir == "backward")
{
pos.y--;
}
else if(dir == "left")
{
pos.x--;
}
else if(dir == "right")
{
pos.x++;
}
}
}