class walking_object: moving_object
{
timer movetimer;
int speed;
walking_object(int x, int y, int z = 0, int speed = 150)
{
super(x,y, z);
this.speed = speed;
}
bool can_move()
{
return movetimer.elapsed>=speed;
}
void move(string dir)
{
if(!can_move())
{
return;
}
moving_object::move(dir);
movetimer.restart();
}
}